# 云商后端服务环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=yunshang

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 微信支付配置
WECHAT_PAY_APPID=your_wechat_appid
WECHAT_PAY_MCHID=your_merchant_id
WECHAT_PAY_KEY=your_api_key
WECHAT_PAY_NOTIFY_URL=http://your-domain.com/api/pay/wechat/notify

# 支付宝配置
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_NOTIFY_URL=http://your-domain.com/api/pay/alipay/notify

# 快递100配置
KUaidi100_KEY=your_kuaidi100_key
KUaidi100_CUSTOMER=your_customer_id
KUaidi100_CALLBACK_URL=http://your-domain.com/api/shipping/kuaidi100/callback
